local function addButton(container, data, theme)
    local f = baseFrame(container, 40, theme)
    local bar = accentBar(f, true, theme)
    local lbl = elemLabel(f, data.Name or "Button", theme)
    local arrow = new("TextLabel", f, {
        Text = ">",
        TextColor3 = theme.TextDim,
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        Size = UDim2.new(0,24, 1, 0),
        Position = UDim2.new(1,-28, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = 6,
    })
    local cb = data.Callback or function() end
    new("TextButton", f, {
        Size = UDim2.new(1,0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 7,
    }).MouseButton1Click:Connect(function()
        cb()
        tween(lbl,   0.15, {TextColor3 = Color3.fromRGB(255,255,255)}):Play()
        tween(arrow, 0.15, {TextColor3 = theme.Accent}):Play()
        tween(bar,   0.15, {BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
        task.wait(0.25)
        tween(lbl,   0.2, {TextColor3 = theme.Text}):Play()
        tween(arrow, 0.2, {TextColor3 = theme.TextDim}):Play()
        tween(bar,   0.2, {BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
    end)
    return f
end

local function addToggle(container, data, theme)
    local f = baseFrame(container, 40, theme)
    local bar = accentBar(f, data.Default, theme)
    elemLabel(f, data.Name or "Toggle", theme)
    local track = new("Frame", f, {
        Size = UDim2.new(0,46, 0, 22),
        Position = UDim2.new(1,-58, 0.5, -11),
        BackgroundColor3 = theme.PanelLight,
        ZIndex = 6,
    })
    corner(track, UDim.new(0,11))
    local knob = new("Frame", track, {
        Size = UDim2.new(0,16, 0, 16),
        Position = data.Default and UDim2.new(1,-19, 0.5, -8) or UDim2.new(0,3, 0.5, -8),
        BackgroundColor3 = data.Default and Color3.fromRGB(255,255,255) or theme.TextMuted,
        ZIndex = 7,
    })
    corner(knob, UDim.new(1,0))
    local state = data.Default or false
    local cb = data.Callback or function() end
    new("TextButton", f, {
        Size = UDim2.new(1,0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 8,
    }).MouseButton1Click:Connect(function()
        state = not state
        tween(knob, 0.18, {
            Position = state and UDim2.new(1,-19, 0.5, -8) or UDim2.new(0,3, 0.5, -8),
            BackgroundColor3 = state and Color3.fromRGB(255,255,255) or theme.TextMuted,
        }):Play()
        tween(bar, 0.18, {
            BackgroundColor3 = state and Color3.fromRGB(255,255,255) or theme.TextMuted,
        }):Play()
        cb(state)
    end)
    if data.Default then cb(data.Default) end
    return f
end

local function addDropdown(container, data, theme)
    local options = data.Options or {}
    local default = data.Default or options[1]
    local cb = data.Callback or function() end
    local f = baseFrame(container, 40, theme)
    f.ClipsDescendants = false
    elemLabel(f, data.Name or "Dropdown", theme)
    local valBg = new("Frame", f, {
        Size = UDim2.new(0,140, 0, 26),
        Position = UDim2.new(1,-152, 0.5, -13),
        BackgroundColor3 = theme.PanelLight,
        ZIndex = 6,
    })
    corner(valBg, UDim.new(0,5))
    local valLabel = new("TextLabel", valBg, {
        Text = default or "",
        TextColor3 = theme.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        Size = UDim2.new(1,-24, 1, 0),
        Position = UDim2.new(0,6, 0, 0),
        BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        ZIndex = 7,
    })
    local chevron = new("TextLabel", valBg, {
        Text = "v",
        TextColor3 = theme.TextDim,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        Size = UDim2.new(0,18, 1, 0),
        Position = UDim2.new(1,-20, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = 7,
    })

    local screenGui = cg:FindFirstChild("ScyUI")
    local listBg = new("Frame", screenGui, {
        Size = UDim2.new(0,0, 0,0),
        BackgroundColor3 = theme.Panel,
        BackgroundTransparency = 0.05,
        Visible = false,
        ZIndex = 100,
        ClipsDescendants = true,
    })
    corner(listBg, UDim.new(0,7))

    local listScroll = new("ScrollingFrame", listBg, {
        Size = UDim2.new(1,0, 1,0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = theme.AccentDim,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        CanvasSize = UDim2.new(0,0, 0,0),
        ZIndex = 101,
    })
    new("UIListLayout", listScroll, {Padding = UDim.new(0,3)})
    new("UIPadding", listScroll, {
        PaddingLeft   = UDim.new(0,5),
        PaddingRight  = UDim.new(0,5),
        PaddingTop    = UDim.new(0,5),
        PaddingBottom = UDim.new(0,5),
    })

    local open = false
    local listH = math.min(#options * 28 + 10, 140)

    local function updateListPos()
        local absPos  = f.AbsolutePosition
        local absSize = f.AbsoluteSize
        local screenH = workspace.CurrentCamera.ViewportSize.Y
        local spaceBelow = screenH - (absPos.Y + absSize.Y)
        local spaceAbove = absPos.Y

        local finalH = math.min(listH, math.max(spaceBelow, spaceAbove) - 8)
        local posY
        if spaceBelow >= finalH or spaceBelow >= spaceAbove then
            posY = absPos.Y + absSize.Y + 4
        else
            posY = absPos.Y - finalH - 4
        end

        listBg.Position = UDim2.new(0, absPos.X, 0, posY)
        listBg.Size     = UDim2.new(0, absSize.X, 0, open and finalH or 0)
    end

    local function setOpen(v)
        open = v
        if v then
            updateListPos()
            listBg.Visible = true
        end
        tween(chevron, 0.18, {Rotation = v and 180 or 0}):Play()
        local absSize = f.AbsoluteSize
        local screenH = workspace.CurrentCamera.ViewportSize.Y
        local absPos  = f.AbsolutePosition
        local spaceBelow = screenH - (absPos.Y + absSize.Y)
        local spaceAbove = absPos.Y
        local finalH = math.min(listH, math.max(spaceBelow, spaceAbove) - 8)
        tween(listBg, 0.2, {Size = v
            and UDim2.new(0, absSize.X, 0, finalH)
            or  UDim2.new(0, absSize.X, 0, 0)
        }):Play()
        if not v then
            task.delay(0.21, function() listBg.Visible = false end)
        end
    end

    for _, opt in options do
        local active = opt == default
        local ob = new("TextButton", listScroll, {
            Size = UDim2.new(1,0, 0, 26),
            BackgroundColor3 = active and theme.AccentDim or theme.PanelAlt,
            BackgroundTransparency = active and 0.4 or 0.6,
            Text = "",
            AutoButtonColor = false,
            ZIndex = 102,
        })
        corner(ob, UDim.new(0,5))
        new("TextLabel", ob, {
            Text = opt,
            TextColor3 = active and Color3.fromRGB(255,255,255) or theme.TextDim,
            Font = Enum.Font.GothamBold,
            TextSize = 12,
            Size = UDim2.new(1,-10, 1, 0),
            Position = UDim2.new(0,8, 0, 0),
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 103,
        })
        ob.MouseButton1Click:Connect(function()
            for _, b in listScroll:GetChildren() do
                if b:IsA("TextButton") then
                    tween(b, 0.12, {BackgroundTransparency=0.6, BackgroundColor3=theme.PanelAlt}):Play()
                    local l = b:FindFirstChildWhichIsA("TextLabel")
                    if l then tween(l, 0.12, {TextColor3=theme.TextDim}):Play() end
                end
            end
            tween(ob, 0.12, {BackgroundTransparency=0.4, BackgroundColor3=theme.AccentDim}):Play()
            local l = ob:FindFirstChildWhichIsA("TextLabel")
            if l then tween(l, 0.12, {TextColor3=Color3.fromRGB(255,255,255)}):Play() end
            valLabel.Text = opt
            cb(opt)
            setOpen(false)
        end)
    end

    new("TextButton", valBg, {
        Size = UDim2.new(1,0, 1,0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 8,
    }).MouseButton1Click:Connect(function() setOpen(not open) end)

    uis.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 and open then
            local mp = uis:GetMouseLocation()
            local lp2 = listBg.AbsolutePosition
            local ls2 = listBg.AbsoluteSize
            if mp.X < lp2.X or mp.X > lp2.X+ls2.X or mp.Y < lp2.Y or mp.Y > lp2.Y+ls2.Y then
                local fp = f.AbsolutePosition
                local fs = f.AbsoluteSize
                if not(mp.X >= fp.X and mp.X <= fp.X+fs.X and mp.Y >= fp.Y and mp.Y <= fp.Y+fs.Y) then
                    setOpen(false)
                end
            end
        end
    end)

    if default then cb(default) end
    return f
end

local function addTextbox(container, data, theme)
    local cb = data.Callback or function() end
    local f = baseFrame(container, 40, theme)
    elemLabel(f, data.Name or "TextBox", theme)
    local boxBg = new("Frame", f, {
        Size = UDim2.new(0,130, 0, 26),
        Position = UDim2.new(1,-140, 0.5, -13),
        BackgroundColor3 = theme.PanelLight,
        ZIndex = 6,
    })
    corner(boxBg, UDim.new(0,5))
    local box = new("TextBox", boxBg, {
        Size = UDim2.new(1,-8, 1, 0),
        Position = UDim2.new(0,4, 0, 0),
        BackgroundTransparency = 1,
        ClearTextOnFocus = data.AutoClear or false,
        Text = data.Default or "",
        PlaceholderText = data.PlaceHolder or "...",
        TextColor3 = theme.Text,
        PlaceholderColor3 = theme.TextMuted,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 7,
    })
    box.Focused:Connect(function()
        tween(boxBg, 0.15, {BackgroundColor3 = theme.PanelAlt}):Play()
    end)
    box.FocusLost:Connect(function()
        tween(boxBg, 0.15, {BackgroundColor3 = theme.PanelLight}):Play()
        cb(box.Text)
    end)
    cb(data.Default or "")
    return {Frame = f, Box = box}
end

