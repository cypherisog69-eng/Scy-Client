local function new(class, parent, props)
    local o = Instance.new(class)
    if parent then o.Parent = parent end
    if props then for k,v in pairs(props) do o[k] = v end end
    return o
end

local function corner(p, r)
    return new("UICorner", p, {CornerRadius = r or UDim.new(0,6)})
end

local function tween(o, t, props, style, dir)
    return ts:Create(o,
        TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props)
end

local function draggable(f)
    local dragging, inp, mpos, fpos
    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mpos = i.Position
            fpos = f.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    f.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then
            inp = i
        end
    end)
    uis.InputChanged:Connect(function(i)
        if i == inp and dragging then
            local d = i.Position - mpos
            f.Position = UDim2.new(
                fpos.X.Scale, fpos.X.Offset + d.X,
                fpos.Y.Scale, fpos.Y.Offset + d.Y
            )
        end
    end)
end

local function baseFrame(parent, h, theme)
    local f = new("Frame", parent, {
        Size = UDim2.new(1,-4, 0, h or 38),
        BackgroundColor3 = theme.Panel,
        BackgroundTransparency = 0.1,
        ZIndex = 5,
    })
    corner(f, UDim.new(0,7))
    f.MouseEnter:Connect(function() tween(f, 0.15, {BackgroundTransparency=0}):Play() end)
    f.MouseLeave:Connect(function() tween(f, 0.15, {BackgroundTransparency=0.1}):Play() end)
    return f
end

