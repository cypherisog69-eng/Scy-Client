            Padding = UDim.new(0,5),
        })
        new("TextLabel", c, {
            Text = icon,
            TextColor3 = Color3.fromRGB(160,200,255),
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            BackgroundTransparency = 1,
            AutomaticSize = Enum.AutomaticSize.X,
            Size = UDim2.new(0,0, 1, 0),
        })
        return new("TextLabel", c, {
            Text = "--" .. suffix,
            TextColor3 = Color3.fromRGB(255,255,255),
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            BackgroundTransparency = 1,
            AutomaticSize = Enum.AutomaticSize.X,
            Size = UDim2.new(0,0, 1, 0),
        })
    end

    local fpsLabel  = statItem("FPS", " FPS", 1)
    local pingLabel = statItem("MS",  " MS",  2)
    local timeLabel = statItem("T",   "",     3)

    local function topBtn(text, posX, color)
        local btn = new("TextButton", topbar, {
            Text = text,
            TextColor3 = color or theme.TextDim,
            Font = Enum.Font.GothamBold,
            TextSize = 22,
            Size = UDim2.new(0,28, 0, 28),
            Position = UDim2.new(1,posX, 0, 5),
            BackgroundColor3 = theme.PanelAlt,
            BackgroundTransparency = 0.4,
            AutoButtonColor = false,
            ZIndex = 7,
        })
        corner(btn, UDim.new(0,5))
        btn.MouseEnter:Connect(function() tween(btn,0.15,{BackgroundTransparency=0}):Play() end)
        btn.MouseLeave:Connect(function() tween(btn,0.15,{BackgroundTransparency=0.4}):Play() end)
        return btn
    end

    local minBtn   = topBtn("-", -65, theme.Text)
    local closeBtn = topBtn("x", -33, Color3.fromRGB(255,255,255))

    local fullSize = UDim2.new(0.52,0, 0.62,0)
    local miniSize = UDim2.new(0.52,0, 0, 42)
    local minimized = false
    local hideable = {}
    task.delay(0, function()
        for _, c in main:GetChildren() do
            if c ~= topbar and c ~= accentLine then
                table.insert(hideable, c)
            end
        end
    end)

    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            main.ClipsDescendants = true
            tween(main, 0.22, {Size=miniSize}):Play()
            task.delay(0.1, function()
                for _, c in ipairs(hideable) do
                    c.Visible = false
                end
            end)
            minBtn.Text = "+"
        else
            for _, c in ipairs(hideable) do
                c.Visible = true
            end
            main.ClipsDescendants = false
            tween(main, 0.22, {Size=fullSize}):Play()
            task.delay(0.22, function()
                main.ClipsDescendants = true
            end)
            minBtn.Text = "-"
        end
    end)

    closeBtn.MouseButton1Click:Connect(function()
        tween(main, 0.2, {Size=UDim2.new(0,0,0,0)}, Enum.EasingStyle.Back, Enum.EasingDirection.In):Play()
        task.delay(0.18, function() screen:Destroy() end)
    end)

    local nav = new("Frame", main, {
        Size = UDim2.new(0,170, 1, -46),
        Position = UDim2.new(0,2, 0, 42),
        BackgroundColor3 = theme.Panel,
        BackgroundTransparency = 0.2,
        ZIndex = 3,
    })
    corner(nav, UDim.new(0,8))
    new("UIPadding", nav, {
        PaddingTop    = UDim.new(0,8),
        PaddingBottom = UDim.new(0,8),
        PaddingLeft   = UDim.new(0,6),
        PaddingRight  = UDim.new(0,6),
    })

    local navScroll = new("ScrollingFrame", nav, {
        Size = UDim2.new(1,0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = theme.AccentDim,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        CanvasSize = UDim2.new(0,0, 0, 0),
    })
    new("UIListLayout", navScroll, {Padding = UDim.new(0,5)})

    local content = new("Frame", main, {
        Size = UDim2.new(1,-180, 1, -50),
        Position = UDim2.new(0,176, 0, 46),
        BackgroundColor3 = theme.PanelAlt,
        BackgroundTransparency = 0.4,
        ZIndex = 3,
        ClipsDescendants = false,
    })
    corner(content, UDim.new(0,8))
    new("UIPadding", content, {
        PaddingLeft   = UDim.new(0,8),
        PaddingRight  = UDim.new(0,8),
        PaddingTop    = UDim.new(0,8),
        PaddingBottom = UDim.new(0,8),
    })

    local tabs   = {}
    local curTab = nil

    local notifContainer = new("Frame", screen, {
        Size = UDim2.new(0,280, 1, 0),
        Position = UDim2.new(1,-10, 0, 0),
        AnchorPoint = Vector2.new(1,0),
        BackgroundTransparency = 1,
        ZIndex = 20,
    })
    new("UIPadding", notifContainer, {
        PaddingBottom = UDim.new(0,30),
        PaddingTop    = UDim.new(0,60),
    })
    new("UIListLayout", notifContainer, {
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding = UDim.new(0,8),
    })

    local function notify(title, desc, dur)
        dur = dur or 5
        local nf = new("Frame", notifContainer, {
            Size = UDim2.new(1,-10, 0, 72),
            BackgroundColor3 = theme.Panel,
            BackgroundTransparency = 0.05,
            ZIndex = 21,
        })
        corner(nf, UDim.new(0,8))
        local stripe = new("Frame", nf, {
            Size = UDim2.new(1,0, 0, 2),
            BackgroundColor3 = theme.Accent,
            ZIndex = 22,
        })
        new("UIGradient", stripe, {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,   Color3.fromRGB(255,255,255)),
                ColorSequenceKeypoint.new(0.5, theme.AccentGlow),
                ColorSequenceKeypoint.new(1,   Color3.fromRGB(255,255,255)),
            }),
        })
        new("TextLabel", nf, {
            Text = title,
            TextColor3 = Color3.fromRGB(255,255,255),
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            Size = UDim2.new(1,-30, 0, 22),
            Position = UDim2.new(0,10, 0, 6),
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 22,
        })
        new("TextLabel", nf, {
            Text = desc,
            TextColor3 = theme.Text,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            Size = UDim2.new(1,-20, 0, 34),
            Position = UDim2.new(0,10, 0, 28),
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            ZIndex = 22,
        })
        new("TextButton", nf, {
            Text = "x",
            TextColor3 = theme.TextMuted,
            Font = Enum.Font.GothamBold,
            TextSize = 18,
            Size = UDim2.new(0,20, 0, 20),
            Position = UDim2.new(1,-24, 0, 4),
            BackgroundTransparency = 1,
            ZIndex = 23,
        }).MouseButton1Click:Connect(function() nf:Destroy() end)
        local prog = new("Frame", nf, {
            Size = UDim2.new(1,-20, 0, 2),
            Position = UDim2.new(0,10, 1, -6),
            BackgroundColor3 = theme.AccentDim,
            ZIndex = 22,
        })
        corner(prog, UDim.new(0,1))
        local tw = tween(prog, dur, {Size=UDim2.new(0,0, 0, 2)}, Enum.EasingStyle.Linear)
        tw:Play()
        tw.Completed:Connect(function() nf:Destroy() end)
    end

    local fab = new("ImageButton", screen, {
        BackgroundTransparency = 1,
        Size = UDim2.new(0,48, 0, 48),
        Position = UDim2.new(0,16, 0, 68),
        ZIndex = 15,
    })
    draggable(fab)

    local mainVisible = true
    local origSize    = main.Size

    local function hideMain()
        mainVisible = false
        tween(main, 0.22, {Size=UDim2.new(0,0,0,0)}, Enum.EasingStyle.Back, Enum.EasingDirection.In):Play()
        task.delay(0.18, function() main.Visible = false; main.Size = origSize end)
        tween(fab, 0.15, {ImageTransparency=0.4}):Play()
    end
    local function showMain()
        mainVisible = true
        main.Visible = true
        main.Size = UDim2.new(0,0, 0, 0)
        tween(main, 0.28, {Size=origSize}, Enum.EasingStyle.Back, Enum.EasingDirection.Out):Play()
        tween(fab,  0.15, {ImageTransparency=0}):Play()
    end

    fab.MouseButton1Click:Connect(function()
        if mainVisible then hideMain() else showMain() end
    end)
    uis.InputBegan:Connect(function(i)
        if i.UserInputState == Enum.UserInputState.Begin
        and i.KeyCode == Enum.KeyCode.LeftControl then
            if mainVisible then hideMain() else showMain() end
        end
    end)

    do
        local frames, lastTick = 0, tick()
        rs.RenderStepped:Connect(function()
            frames += 1
            local now = tick()
            if now - lastTick >= 1 then
                local fps  = frames; frames = 0; lastTick = now
                local ping = tonumber(stats.Network.ServerStatsItem["Data Ping"]:GetValueString():match("%d+")) or 0
                pingLabel.Text = ping .. " MS"
                pingLabel.TextColor3 = ping>=350 and theme.Danger or ping>=180 and theme.Warning or theme.Success
                fpsLabel.Text = fps .. " FPS"
                fpsLabel.TextColor3 = fps<20 and theme.Danger or fps<=40 and theme.Warning or theme.Success
            end
        end)
        task.spawn(function()
            while task.wait(1) do
                local t = workspace.DistributedGameTime
                timeLabel.Text = string.format("%02d:%02d:%02d",
                    math.floor(t/3600), math.floor(t%3600/60), math.floor(t%60))
            end
        end)
    end

    local window = {}

    function window:Tab(name, icon)
        local btn = new("TextButton", navScroll, {
            Text = "",
            Size = UDim2.new(1,0, 0, 32),
            BackgroundColor3 = theme.PanelAlt,
            BackgroundTransparency = 0.6,
            AutoButtonColor = false,
            ZIndex = 4,
        })
        corner(btn, UDim.new(0,6))
        local indicator = new("Frame", btn, {
            Size = UDim2.new(0,3, 0.6, 0),
            Position = UDim2.new(0,4, 0.2, 0),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BackgroundTransparency = 1,
            ZIndex = 5,
        })
        corner(indicator, UDim.new(1,0))
        local lbl = new("TextLabel", btn, {
            Text = (icon or "o") .. "  " .. name,
            TextColor3 = theme.TextDim,
            Font = Enum.Font.GothamBold,
            TextSize = 13,
            Size = UDim2.new(1,-14, 1, 0),
            Position = UDim2.new(0,14, 0, 0),
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 5,
        })
        local scroll = new("ScrollingFrame", content, {
            Name = name,
            Size = UDim2.new(1,0, 1, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.AccentDim,
            ScrollingDirection = Enum.ScrollingDirection.Y,
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            CanvasSize = UDim2.new(0,0, 0, 0),
            Visible = false,
            ZIndex = 4,
        })
        new("UIListLayout", scroll, {
            Padding = UDim.new(0,7),
            HorizontalAlignment = Enum.HorizontalAlignment.Center,
        })
        new("UIPadding", scroll, {
            PaddingTop    = UDim.new(0,2),
            PaddingBottom = UDim.new(0,12),
        })
        tabs[name] = {scroll=scroll, btn=btn, indicator=indicator, label=lbl}

        local function activate()
            for n, t in tabs do
                local active = n == name
                tween(t.indicator, 0.18, {BackgroundTransparency = active and 0 or 1}):Play()
                tween(t.btn,       0.18, {BackgroundTransparency = active and 0.1 or 0.6}):Play()
                tween(t.label,     0.18, {TextColor3 = active and Color3.fromRGB(255,255,255) or theme.TextDim}):Play()
                t.scroll.Visible = active
            end
            curTab = name
        end
        btn.MouseButton1Click:Connect(activate)
        if not curTab then activate() end

        local tab = {}

        function tab:Section(text)
            return addSection(scroll, text, theme)
        end
        function tab:Button(data)
            return addButton(scroll, data, theme)
        end
        function tab:Toggle(data)
            return addToggle(scroll, data, theme)
        end
        function tab:Dropdown(data)
            return addDropdown(scroll, data, theme)
        end
        function tab:Textbox(data)
            return addTextbox(scroll, data, theme)
        end

        return tab
    end

    function window:Notify(title, desc, dur)
        notify(title, desc, dur)
    end

    return window
end

return ScyLib
